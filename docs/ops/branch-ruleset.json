{
  "name": "protect-main",
  "target": "branch",
  "enforcement": "active",
  "conditions": {
    "ref_name": {
      "include": ["refs/heads/main"],
      "exclude": []
    }
  },
  "rules": [
    {
      "type": "required_status_checks",
      "parameters": {
        "strict_required_status_checks_policy": false,
        "do_not_enforce_on_create": false,
        "required_status_checks": [
          { "context": "Lighthouse performance budget" },
          { "context": "zizmor (workflow SAST)" },
          { "context": "Lint · Typecheck · Unit · Build (Node 20)" },
          { "context": "Lint · Typecheck · Unit · Build (Node 22)" },
          { "context": "Security (dependency audit + secret scan)" },
          { "context": "End-to-end (Chromium + Firefox)" },
          { "context": "standards" }
        ]
      }
    },
    { "type": "non_fast_forward" },
    { "type": "deletion" }
  ]
}
