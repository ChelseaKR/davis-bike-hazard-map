{
  "name": "davis-bike-hazard-map",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Crowdsourced, offline-first cycling-hazard map for Davis, CA — an installable PWA.",
  "license": "MIT",
  "engines": {
    "node": ">=20 <23"
  },
  "scripts": {
    "dev": "concurrently -n client,server -c cyan,magenta \"npm:dev:client\" \"npm:dev:server\"",
    "prepare": "husky || true",
    "dev:client": "vite",
    "dev:server": "tsx watch server/index.ts",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "start": "cross-env NODE_ENV=production tsx server/index.ts",
    "seed": "tsx scripts/seed.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "lint:css": "stylelint \"src/**/*.css\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run",
    "test:coverage": "vitest run --coverage",
    "a11y": "vitest run a11y",
    "e2e": "playwright test",
    "e2e:i18n": "node scripts/i18n/gen-pseudo.mjs && playwright test --config playwright.i18n.config.ts",
    "i18n:extract": "formatjs extract 'src/**/*.{ts,tsx}' --out-file src/i18n/locales/en.json --throws --format simple && node scripts/i18n/sync-es-skeleton.mjs",
    "i18n:utf8": "node scripts/i18n/check-utf8.mjs",
    "i18n:no-hardcoded": "node scripts/i18n/check-no-hardcoded.mjs",
    "i18n:extract:check": "node scripts/i18n/check-extract.mjs",
    "i18n:bcp47": "node scripts/i18n/check-bcp47.mjs",
    "i18n:parity": "node scripts/i18n/check-parity.mjs",
    "i18n:cldr": "node scripts/i18n/check-cldr-pin.mjs",
    "i18n:pseudo:gen": "node scripts/i18n/gen-pseudo.mjs",
    "i18n:gates": "npm run i18n:utf8 && npm run i18n:extract:check && npm run i18n:no-hardcoded && npm run i18n:bcp47 && npm run i18n:parity && npm run i18n:cldr",
    "verify": "npm run lint && npm run lint:css && npm run i18n:gates && npm run typecheck && npm run test:unit && npm run build"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs}": "eslint --fix"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^7.3.4",
    "@aws-sdk/client-s3": "^3.1085.0",
    "@fastify/cors": "^10.0.1",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^10.1.1",
    "@fastify/static": "^9.1.1",
    "@formatjs/intl": "^3.1.8",
    "@sentry/node": "^10.65.0",
    "fastify": "^5.1.0",
    "idb": "^8.0.0",
    "leaflet": "^1.9.4",
    "leaflet.markercluster": "^1.5.3",
    "pg": "^8.21.0",
    "prom-client": "^15.1.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-intl": "^7.1.14",
    "react-leaflet": "^5.0.0",
    "sharp": "^0.33.5",
    "tsx": "^4.19.2",
    "web-push": "^3.6.7",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.1",
    "@eslint/js": "^9.17.0",
    "@formatjs/cli": "^6.16.11",
    "@playwright/test": "^1.49.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/leaflet": "^1.9.15",
    "@types/node": "^22.10.2",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/web-push": "^3.6.4",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^3.2.7",
    "aws-sdk-client-mock": "^4.1.0",
    "axe-core": "^4.10.2",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "eslint": "^9.17.0",
    "eslint-plugin-formatjs": "^6.4.16",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^5.1.0",
    "fake-indexeddb": "^6.0.0",
    "fast-check": "^4.8.0",
    "globals": "^15.14.0",
    "husky": "^9.1.7",
    "jsdom": "^25.0.1",
    "lint-staged": "^15.5.2",
    "stylelint": "16.26.1",
    "stylelint-use-logical": "2.1.3",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1",
    "vite": "^6.0.5",
    "vite-plugin-pwa": "^0.21.1",
    "vitest": "^3.2.7"
  }
}
