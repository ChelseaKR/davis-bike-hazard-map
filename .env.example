# Davis Bike Hazard Map — environment configuration.
# Copy to .env (gitignored) and adjust. The app runs with all defaults unset.

# --- Server ---
# Port the API/SPA server listens on.
PORT=8787
# Production store: PostgreSQL. When set, the Postgres repository is used.
# REQUIRED IN PRODUCTION — the server refuses to boot without it.
#   docker compose up -d db   # then:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/dbhm
DATABASE_URL=
# Dev/MVP fallback: a single JSON file (used only when DATABASE_URL is unset).
# Leave empty for in-memory (dev/test). SINGLE-PROCESS only — never run two
# instances against one file (no cross-process lock; concurrent writes corrupt it).
DATABASE_PATH=./data/hazards.json
# --- Moderator accounts ---
# REQUIRED IN PRODUCTION: secret used to sign moderator session tokens.
SESSION_SECRET=
# Moderator session lifetime (hours).
SESSION_TTL_HOURS=12
# Bootstrap moderator, created on first boot if it doesn't exist. In dev these
# default to admin/admin; set real values in production (and rotate the password
# from inside the app, or by re-seeding). Reporters never have accounts.
MODERATOR_USERNAME=
MODERATOR_PASSWORD=
# Serve the built client from ./dist (auto-enabled when NODE_ENV=production).
SERVE_CLIENT=false

# --- Optional 311 / GOGov hand-off + status sync-back ---
# Leave empty to run hand-off in dry-run mode (returns the payload, sends nothing).
GOGOV_WEBHOOK_URL=
GOGOV_API_KEY=
# Optional status-poll endpoint: a moderator "sync" does GET {url}/{reference}.
# Empty => the sync poll dry-runs (no network).
GOGOV_STATUS_URL=
# Shared secret a 311/GOGov webhook must send as the x-gogov-signature header to
# push a status back (POST /api/handoff/webhook). Empty => that webhook is
# DISABLED (503) so no unauthenticated status writes are accepted.
GOGOV_WEBHOOK_SECRET=
# How long a resolved hazard stays visible (greyed) on the public map, in days.
RESOLVED_VISIBLE_DAYS=7

# --- Hazard-aware route planner (OSRM cycling backend, proxied by /api/route) ---
# Default is the public OSRM demo server; self-host for production / heavy use
# (https://github.com/Project-OSRM/osrm-backend). Empty => straight-line fallback.
ROUTING_URL=https://router.project-osrm.org/route/v1/cycling

# --- Optional web-push alerts for saved routes/areas (OFF by default) ---
# Generate a VAPID key pair (e.g. `npx web-push generate-vapid-keys`) and set
# PUSH_ENABLED=true to deliver. Without keys the matcher runs in dry-run.
PUSH_ENABLED=false
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:hazards@davisbikehazardmap.org

# --- Optional error reporting (server-side Sentry) ---
# Client errors beacon to /api/client-errors and are forwarded here. Empty => off.
SENTRY_DSN=

# --- Optional object storage for photos (S3 / Cloudflare R2 / MinIO) ---
# When S3_BUCKET is set, photos live in object storage instead of local disk
# (stateless app instances + CDN-friendly). Credentials come from the standard
# AWS env/instance chain (AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY).
S3_BUCKET=
S3_PREFIX=photos/
# S3_ENDPOINT=https://<account>.r2.cloudflarestorage.com   # for R2/MinIO
S3_REGION=auto

# --- Rate limiting ---
RATE_LIMIT_MAX=120
RATE_LIMIT_WINDOW_MS=60000
REPORTS_PER_HOUR=30

# --- Hazard lifecycle (days before auto-expiry, by severity) ---
TTL_LOW_DAYS=14
TTL_MODERATE_DAYS=21
TTL_HIGH_DAYS=30

# --- Data backups (JSON store only; the file store has no point-in-time recovery) ---
# Where timestamped snapshots are written. Defaults to a backups/ dir beside
# DATABASE_PATH; leave unset to use that default, or empty to disable.
# BACKUP_DIR=./data/backups
BACKUP_INTERVAL_HOURS=6
BACKUP_RETAIN=14

# --- Client (build-time, VITE_*) ---
# Override the API base or tile server if self-hosting tiles.
# VITE_API_BASE=/api
# VITE_TILE_URL=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png
# Public read-only dashboard: hides report/my-reports/moderation, shows only the
# map/list/coverage/route views. Set true for the public, no-auth deployment.
# VITE_PUBLIC_DASHBOARD=false
# Render the saved-route push-alert UI (needs the server PUSH_ENABLED + VAPID).
# VITE_PUSH_ENABLED=false
